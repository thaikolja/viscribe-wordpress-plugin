{# API Key Field Template #}

{# ── Notification Banner ── #}
{% if using_api_key_constant %}
    <div class="viscribe-api-key-notice viscribe-api-key-notice--active" role="status" aria-live="polite">
        <div class="viscribe-api-key-notice-icon" aria-hidden="true">
            <span class="dashicons dashicons-shield-alt"></span>
        </div>
        <div class="viscribe-api-key-notice-body">
            <strong>{% trans %}API key loaded from wp-config.php{% endtrans %}</strong>
            <p>{% trans %}Your Groq API key is securely defined via the{% endtrans %}
                <code>VISCRIBE_API_KEY</code> {% trans %}constant and takes priority over any key entered below.{% endtrans %}
            </p>
        </div>
    </div>
{% else %}
    <div class="viscribe-api-key-notice viscribe-api-key-notice--tip" role="note">
        <div class="viscribe-api-key-notice-icon" aria-hidden="true">
            <span class="dashicons dashicons-info-outline"></span>
        </div>
        <div class="viscribe-api-key-notice-body">
            <strong>{% trans %}Recommended: Define your API key in wp-config.php{% endtrans %}</strong>
            <p id="viscribe_api_key_tip_desc">{% trans %}For stronger security, add this constant to your{% endtrans %}
                <code>wp-config.php</code>{% trans %}. It will automatically override the key entered below.{% endtrans %}
            </p>
            <div class="viscribe-api-key-notice-snippet" aria-label="{% trans %}Code block showing how to define API key in wp-config.php{% endtrans %}" tabindex="0">
                <code>define( 'VISCRIBE_API_KEY', 'gsk_YOUR_GROQ_API_KEY_HERE' );</code>
            </div>
        </div>
    </div>
{% endif %}

{# ── API Key Input Row ── #}
<div class="viscribe-setting-row viscribe-setting-row--stacked">
    <div class="viscribe-setting-label">
        <label for="viscribe_api_key">{% trans %}Groq API Key{% endtrans %}
            <span class="viscribe-label-required" aria-label="{% trans %}Required field{% endtrans %}">{% trans %}Required{% endtrans %}</span>
        </label>
        <p class="viscribe-setting-description" id="viscribe_api_key_desc">
            {% if using_api_key_constant %}
                {% trans %}The API key is managed through your wp-config.php constant.{% endtrans %}
            {% elseif saved %}
                {% trans %}Your key is encrypted and saved. Enter a new key to overwrite it.{% endtrans %}
            {% else %}
                {% trans %}Enter your Groq API key. Keys start with gsk_ and are 56 characters long.{% endtrans %}
            {% endif %}
        </p>
    </div>
    <div class="viscribe-setting-control viscribe-setting-control--full">
        <div class="viscribe-api-key-input-row{{ using_api_key_constant ? ' viscribe-api-key-input-row--disabled' : '' }}">
            {% if using_api_key_constant %}
                <input
                        type="text" id="viscribe_api_key" value="{% trans %}Defined in wp-config.php...{% endtrans %}" class="viscribe-api-key-field" disabled readonly aria-describedby="viscribe_api_key_desc" />
            {% else %}
                <input
                        type="text" id="viscribe_api_key" name="{{ option_name }}[api_key]" value="{{ display_key }}" class="viscribe-api-key-field" placeholder="{{ placeholder }}" autocomplete="off" aria-describedby="viscribe_api_key_desc" aria-required="true" aria-invalid="false" />
            {% endif %}
            <button
                    type="button" id="viscribe_delete_api_key" class="viscribe-api-key-delete" title="{% trans %}Delete saved key from database{% endtrans %}" aria-label="{% trans %}Delete saved key{% endtrans %}"
                    {{ not saved or using_api_key_constant ? 'disabled aria-disabled="true"' : '' }}>
                <span class="dashicons dashicons-trash" aria-hidden="true"></span>
                <span aria-hidden="true">{% trans %}Delete{% endtrans %}</span>
            </button>
        </div>
        {# Inline validation error (injected by JS) #}
        <div id="viscribe-api-key-error-msg" class="viscribe-api-key-error" style="display:none;" role="alert" aria-live="assertive"></div>
    </div>
</div>

{# ── Get Key + Test Connection ── #}
<div class="viscribe-setting-row viscribe-setting-row--stacked" style="border-bottom: none; padding-bottom: 0;">
    <div class="viscribe-setting-label">
        <label id="viscribe_connection_label">{% trans %}Connection{% endtrans %}</label>
        <p class="viscribe-setting-description" id="viscribe_connection_desc">{% trans %}Verify that WordPress can reach Groq with the configured API key.{% endtrans %}</p>
    </div>
    <div class="viscribe-setting-control viscribe-setting-control--full">
        <div class="viscribe-connection-row" role="group" aria-labelledby="viscribe_connection_label" aria-describedby="viscribe_connection_desc">
            <a
                    href="https://console.groq.com/keys" target="_blank" rel="noopener noreferrer" class="viscribe-btn viscribe-btn--secondary" aria-label="{% trans %}Get a free API key from Groq{% endtrans %}">
                <span class="dashicons dashicons-external" aria-hidden="true"></span>
                <span aria-hidden="true">{% trans %}Get Free API Key{% endtrans %}</span> </a>
            <button
                    type="button" id="viscribe_test_connection" class="viscribe-btn viscribe-btn--primary" aria-label="{% trans %}Test the configured API connection{% endtrans %}">
                <span class="dashicons dashicons-update" aria-hidden="true"></span>
                <span aria-hidden="true">{% trans %}Test Connection{% endtrans %}</span>
            </button>
            <div id="viscribe_test_result" class="viscribe-status-badge viscribe-status-badge--idle" role="status" aria-live="polite">
                <span class="dashicons dashicons-lightbulb" aria-hidden="true"></span>
                <span class="viscribe-status-badge-text">{% trans %}Not tested{% endtrans %}</span>
            </div>
        </div>
    </div>
</div>
