{# Model Selection Field Template #}
{% for model_id, model in models %}
    <label class="viscribe-model-card {{ current == model_id ? 'selected' : '' }} {{ model.deprecated ? 'viscribe-model-card--deprecated' : '' }}">
        <input type="radio" name="{{ option_name }}[model]" value="{{ model_id }}" {{ current == model_id ? 'checked' : '' }} {{ model.deprecated ? 'disabled' : '' }}/>
        <span id="viscribe-model-{{ slug(model_id) }}" class="viscribe-model-content">
            <div class="viscribe-model-header">
                <article class="viscribe-model-title-group">
                    <strong>{{ model.label }}</strong>
                    {% if model.deprecated %}
                        <span class="viscribe-model-badge viscribe-model-badge--deprecated">
                            {% trans %}Unavailable{% endtrans %}
                        </span>
                    {% endif %}
                    {% if model.provider == 'meta' %}
                        <img src="{{ asset_url }}/icons/{{ model.provider }}-icon.svg" width="20" height="20" alt="{{ model.provider|capitalize }} {% trans %}logo{% endtrans %}">
                    {% endif %}
                </article>
                {% if current == model_id and not model.deprecated %}
                    <span class="dashicons dashicons-yes"></span>
                {% endif %}
            </div>
            <p class="viscribe-model-description">{{ model.desc }}</p>

            {% if model.specs %}
                {% set params_title %}{% trans %}Parameters{% endtrans %}{% endset %}
                {% set context_title %}{% trans %}Context Window{% endtrans %}{% endset %}
                {% set speed_title %}{% trans %}Speed{% endtrans %}{% endset %}
                {% set size_title %}{% trans %}Max File Size{% endtrans %}{% endset %}
                <article class="viscribe-model-specs">
                    <div class="viscribe-spec-item {{ 'params' in model.highlights|default([]) ? 'viscribe-spec-highlight' : '' }}" title="{{ params_title|e }}">
                        <span class="dashicons dashicons-networking"></span>
                        <span class="viscribe-spec-label">{% trans %}Params:{% endtrans %}</span>
                        <span>{{ model.specs.params }}</span>
                    </div>
                    <div class="viscribe-spec-item {{ 'context' in model.highlights|default([]) ? 'viscribe-spec-highlight' : '' }}" title="{{ context_title|e }}">
                        <span class="dashicons dashicons-editor-expand"></span>
                        <span class="viscribe-spec-label">{% trans %}Context:{% endtrans %}</span>
                        <span>{{ model.specs.context }}</span>
                    </div>
                    <div class="viscribe-spec-item {{ 'speed' in model.highlights|default([]) ? 'viscribe-spec-highlight' : '' }}" title="{{ speed_title|e }}">
                        <span class="dashicons dashicons-performance"></span>
                        <span class="viscribe-spec-label">{% trans %}Speed:{% endtrans %}</span>
                        <span>{{ model.specs.speed }}</span>
                    </div>
                    <div class="viscribe-spec-item {{ 'size' in model.highlights|default([]) ? 'viscribe-spec-highlight' : '' }}" title="{{ size_title|e }}">
                        <span class="dashicons dashicons-media-default"></span>
                        <span class="viscribe-spec-label">{% trans %}Size:{% endtrans %}</span>
                        <span>{{ model.specs.size }}</span>
                    </div>
                </article>
            {% endif %}
        </span>
    </label>
{% endfor %}
