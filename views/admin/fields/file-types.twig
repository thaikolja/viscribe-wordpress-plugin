{# File Types Template #}
<div class="viscribe-card">
	<div class="viscribe-card-header">
		<h2>
			<span class="dashicons dashicons-format-image" aria-hidden="true"></span>
			{% trans %}File Types{% endtrans %}
			<a href="{{ doc_url('usage/settings#file-types') }}" target="_blank" rel="noopener noreferrer" class="viscribe-doc-badge" aria-label="{% trans %}Documentation for File Types{% endtrans %}">
				<span class="dashicons dashicons-book" aria-hidden="true"></span>
				<span aria-hidden="true">{% trans %}Documentation{% endtrans %}</span>
			</a>
		</h2>
		<p class="viscribe-card-description">{% trans %}Select which image formats to process.{% endtrans %}</p>
	</div>
	<div class="viscribe-card-body">
		<div class="viscribe-filetypes-grid" role="group" aria-label="{% trans %}Available file formats{% endtrans %}">
			{% for mime, label in available_types %}
				{% set type_desc = '' %}
			{% if mime == 'image/jpeg' %}{% set type_desc %}{% trans %}Standard image format, best for photographs.{% endtrans %}{% endset %}
			{% elseif mime == 'image/png' %}{% set type_desc %}{% trans %}Lossless format, supports transparency.{% endtrans %}{% endset %}
			{% elseif mime == 'image/webp' %}{% set type_desc %}{% trans %}Modern format, high quality at small file sizes.{% endtrans %}{% endset %}
			{% elseif mime == 'image/gif' %}{% set type_desc %}{% trans %}Static or animated images, limited colors.{% endtrans %}{% endset %}
			{% endif %}

				<label class="viscribe-filetype-card {{ mime in file_types ? 'selected' : '' }}">
					<input type="checkbox" name="{{ option_name }}[file_types][]" value="{{ mime }}" {{ mime in file_types ? 'checked' : '' }} aria-label="{{ label }}{{ type_desc ? ' - ' ~ type_desc : '' }}">
					<span class="viscribe-filetype-icon" aria-hidden="true">
						<span class="dashicons dashicons-media-document"></span>
					</span>
					<span class="viscribe-filetype-content">
						<span class="viscribe-filetype-label">{{ label }}</span>
						{% if type_desc %}
							<span class="viscribe-filetype-desc">{{ type_desc }}</span>
						{% endif %}
					</span>
				</label>
			{% endfor %}
		</div>
	</div>
</div>
