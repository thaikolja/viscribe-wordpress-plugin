{# Advanced Settings Template #}
<div class="viscribe-card">
    <div class="viscribe-card-header">
        <h2>
            <span class="dashicons dashicons-admin-tools"></span>
            {% trans %}Advanced Settings{% endtrans %}
            <a href="{{ doc_url('usage/settings#advanced-settings') }}" target="_blank" rel="noopener noreferrer" class="viscribe-doc-badge"> <span class="dashicons dashicons-book"></span> <span>{% trans %}Documentation{% endtrans %}</span> </a>
        </h2>
        <p class="viscribe-card-description">
            {% trans %}Fine-tune AI behavior and output.{% endtrans %}
        </p>
    </div>
    <div class="viscribe-card-body">
        {# Max Keywords Setting #}
        <div class="viscribe-setting-row">
            <div class="viscribe-setting-label">
                <label for="viscribe_max_keywords">{% trans %}Max Keywords{% endtrans %}</label>
                <p class="viscribe-setting-description">
                    {% trans %}Maximum number of keywords to include in the filename (1-10). Recommended: 5{% endtrans %}
                </p>
            </div>
            <div class="viscribe-setting-control">
                <input type="number" id="viscribe_max_keywords" name="{{ option_name }}[max_keywords]" value="{{ max_keywords }}" min="1" max="10" class="small-text viscribe-number-input">
            </div>
        </div>
    </div>
</div>

{# Diagnostics Card #}
<div class="viscribe-card viscribe-diagnostics-card">
    <div class="viscribe-card-header">
        <h2>
            <span class="dashicons dashicons-info"></span>
            {% trans %}System Diagnostics{% endtrans %}
        </h2>
        <p class="viscribe-card-description">{% trans %}Server information and system requirements.{% endtrans %}</p>
    </div>
    <div class="viscribe-card-body">
        <table class="widefat viscribe-diagnostics-table">
            <tbody>
            {% for key, data in diagnostics %}
                <tr>
                    <td>
                        <strong>{{ data.label }}</strong> <span>{{ data.desc }}</span>
                    </td>
                    <td>
                        <code>{{ data.value }}</code>
                        {% if data.ok %}
                            <span class="dashicons dashicons-yes"></span>
                        {% else %}
                            <span class="dashicons dashicons-warning"></span>
                        {% endif %}
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
