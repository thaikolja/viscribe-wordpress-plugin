{# Models Panel Template #}
<div class="viscribe-card">
    <div class="viscribe-card-header">
        <h2>
            <span class="dashicons dashicons-grid-view"></span>
            {% trans %}AI Models{% endtrans %}
            <a href="{{ doc_url('usage/settings#ai-model') }}" target="_blank" rel="noopener noreferrer" class="viscribe-doc-badge">
                <span class="dashicons dashicons-book"></span>
                <span>{% trans %}Documentation{% endtrans %}</span> </a>
        </h2>
        <p class="viscribe-card-description">{% trans %}Choose which Groq vision model should analyze new uploads.{% endtrans %}</p>
    </div>
    <div class="viscribe-card-body">
        <div class="viscribe-setting-row viscribe-setting-row--stacked">
            <div class="viscribe-setting-control">
                <div class="viscribe-model-cards">
                    {% include 'admin/fields/model.twig' with {
                        models: models,
                        current: current,
                        option_name: option_name,
                        asset_url: asset_url
                    } %}
                </div>
                <p class="deprecation-notice">
                    {% trans %}Llama 4 Maverick was deprecated by Groq on March 9, 2026.{% endtrans %}
                    <a href="https://console.groq.com/docs/deprecations#march-9-2026-metallamallama4maverick17b128einstruct" target="_blank" rel="noopener noreferrer">{% trans %}Read the deprecation notice{% endtrans %}</a>
                </p>
            </div>
        </div>
    </div>
</div>
