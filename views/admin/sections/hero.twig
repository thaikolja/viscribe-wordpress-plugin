{# Hero Section Template - Setup Guide #}
<div class="viscribe-setup-guide postbox">
    <div class="postbox-header">
        <div class="handle-actions">
            <button
                    type="button" class="handlediv" aria-expanded="true">
                <span
                        class="toggle-indicator" aria-hidden="true"></span>
            </button>
        </div>
        <h2 class="hndle ui-sortable-handle">
            <span>
                <span class="dashicons dashicons-info"></span>
                {% trans %}Get Started{% endtrans %}
                <span class="viscribe-version-badge">{% trans %}Free Version{% endtrans %}</span>
            </span>
        </h2>
    </div>
    <div class="inside">
        <p>{% trans %}Follow these steps to start renaming your images automatically using AI:{% endtrans %}</p>
        <ol class="viscribe-setup-steps">
            <li>
                <strong>{% trans %}Get API Key{% endtrans %}</strong>
                <span>{% trans %}Sign up for a free account at the{% endtrans %} <a
							href="https://console.groq.com/keys" target="_blank" rel="noopener noreferrer">{% trans %}Groq Console{% endtrans %}</a>.</span>
            </li>
            <li>
                <strong>{% trans %}Configure Plugin{% endtrans %}</strong>
                <span>{% trans %}Enter your API key below and save the settings.{% endtrans %}</span>
            </li>
            <li>
                <strong>{% trans %}Enable Auto-Rename{% endtrans %}</strong>
                <span>{% trans %}Toggle "Enable Auto-Rename" to start processing new uploads.{% endtrans %}</span>
            </li>
        </ol>
    </div>
</div>

