{# Sidebar Template - Helpful Resources #}
<div class="viscribe-sidebar viscribe-pro-upsell postbox">
    <div class="postbox-header viscribe-pro-header">
        <h2 class="hndle ui-sortable-handle">
			<span>
				<span class="dashicons dashicons-sos"></span>
				{% trans %}Helpful Resources{% endtrans %}
			</span>
        </h2>
    </div>
    <div class="inside">
        <p class="viscribe-pro-tagline">{% trans %}Everything you need to configure the plugin safely and troubleshoot uploads quickly.{% endtrans %}</p>
        <ul class="viscribe-pro-features">
            <li>
                <span class="dashicons dashicons-book-alt"></span>
                <strong>{% trans %}Documentation{% endtrans %}</strong>
                <span>{% trans %}Step-by-step setup guides, technical notes, and hook references.{% endtrans %}</span>
            </li>
            <li>
                <span class="dashicons dashicons-shield-alt"></span>
                <strong>{% trans %}Security{% endtrans %}</strong>
                <span>{% trans %}Use wp-config.php constants when you want the strongest API key handling.{% endtrans %}</span>
            </li>
            <li>
                <span class="dashicons dashicons-format-chat"></span>
                <strong>{% trans %}Support{% endtrans %}</strong>
                <span>{% trans %}Use the WordPress.org support forum if something does not behave as expected.{% endtrans %}</span>
            </li>
            <li>
                <span class="dashicons dashicons-editor-code"></span>
                <strong>{% trans %}Developer Friendly{% endtrans %}</strong>
                <span>{% trans %}Filters and actions are available when you need to adapt the upload workflow.{% endtrans %}</span>
            </li>
        </ul>

    </div>
</div>
