{# Admin Settings Page Template - Modern Tab Layout #}
<div
        class="wrap viscribe-settings-wrap">
    {# Header #}
    {% include 'admin/components/header.twig' %}


    <div
            class="viscribe-settings-container">
        {# Tab Navigation (Sidebar) #}
        <aside class="viscribe-settings-nav">
            {% include 'admin/components/tabs.twig' %}
        </aside>

        {# Main Content Area #}
        <main class="viscribe-settings-content">
            <!--suppress HtmlUnknownTarget -->
            <form method="post" action="options.php" id="viscribe-settings-form">
                {{ settings_fields(option_group)|raw }}

                {# General Settings Panel #}
                <div id="viscribe-panel-general" class="viscribe-panel active" role="tabpanel" aria-labelledby="viscribe-tab-general">
                    {% include 'admin/fields/general.twig' with {
                        option_name: option_name,
                        enabled: enabled,
                        set_alt_text: set_alt_text
                    } %}
                    {% include 'admin/fields/model-limits-info.twig' with {
                        model_limit_info: model_limit_info
                    } %}
                </div>

                {# API Configuration Panel #}
                <div id="viscribe-panel-api" class="viscribe-panel" role="tabpanel" aria-labelledby="viscribe-tab-api" hidden>
                    <div class="viscribe-card">
                        <div class="viscribe-card-header">
                            <h2>
                                <span class="dashicons dashicons-admin-network"></span>
                                {% trans %}API Configuration{% endtrans %}
                                <a href="{{ doc_url('usage/settings#api-configuration') }}" target="_blank" rel="noopener noreferrer" class="viscribe-doc-badge">
                                    <span class="dashicons dashicons-book"></span>
                                    <span>{% trans %}Documentation{% endtrans %}</span> </a>
                            </h2>
                            <p class="viscribe-card-description">{% trans %}Connect to the Groq Vision API to enable AI-powered image renaming.{% endtrans %}</p>
                        </div>
                        <div class="viscribe-card-body">
                            {% include 'admin/fields/api-key.twig' with {option_name: option_name, display_key: display_key, placeholder: placeholder, saved: saved, using_api_key_constant: using_api_key_constant} %}
                        </div>
                    </div>
                </div>

                {# Models Panel #}
                <div id="viscribe-panel-models" class="viscribe-panel" role="tabpanel" aria-labelledby="viscribe-tab-models" hidden>
                    {% include 'admin/fields/models.twig' with {
                        models: models,
                        current: current,
                        option_name: option_name,
                        asset_url: asset_url
                    } %}
                </div>

                {# File Types Panel #}
                <div id="viscribe-panel-filetypes" class="viscribe-panel" role="tabpanel" aria-labelledby="viscribe-tab-filetypes" hidden>
                    {% include 'admin/fields/file-types.twig' with {
                        option_name: option_name,
                        file_types: file_types,
                        available_types: available_types
                    } %}
                </div>

                {# Advanced Settings Panel #}
                <div id="viscribe-panel-advanced" class="viscribe-panel" role="tabpanel" aria-labelledby="viscribe-tab-advanced" hidden>
                    {% include 'admin/fields/advanced.twig' with {
                        option_name: option_name,
                        max_keywords: max_keywords,
                        diagnostics: diagnostics
                    } %}
                </div>

                {# Submit Button #}
                <div class="viscribe-submit-row">
                    <button type="submit" name="submit" id="submit" class="button button-primary viscribe-button-with-icon">
                        <span class="dashicons dashicons-saved"></span>
                        {% trans %}Save Settings{% endtrans %}
                    </button>
                </div>
                {% include 'admin/components/footer.twig' %}
            </form>
        </main>

        {# Sidebar #}
        <aside class="viscribe-settings-sidebar">
            {% include 'admin/sidebar.twig' %}
        </aside>
    </div>
</div>
