{# Header Component - Plugin Branding #}
{% set link = '?page=' ~ page_slug %}
<div class="viscribe-header">
    <div class="viscribe-header-left">
        <a href="{{ link }}">
            <div class="viscribe-header-logo">
                <span class="dashicons dashicons-format-image"></span>
            </div>
        </a>
        <div class="viscribe-header-title">
            <a href="{{ link }}">
                <h1>{{ page_title }}</h1>
            </a>
        </div>
    </div>
    <div class="viscribe-header-center">
        <a href="https://www.paypal.com/paypalme/thaikolja/10/" target="_blank" rel="noopener noreferrer" class="viscribe-donate-card">
            <span class="dashicons dashicons-heart viscribe-donate-card-icon"></span>
            <span class="viscribe-donate-card-text">{% trans %}Helped you? Support future development — Consider donating via PayPal{% endtrans %}</span>
            <svg role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" class="viscribe-donate-card-paypal" width="16" height="16">
                <path d="M7.076 21.337H2.47a.641.641 0 0 1-.633-.74L4.944.901C5.026.382 5.474 0 5.998 0h7.46c2.57 0 4.578.543 5.69 1.81 1.01 1.15 1.304 2.42 1.012 4.287-.023.143-.047.288-.077.437-.983 5.05-4.349 6.797-8.647 6.797h-2.19c-.524 0-.968.382-1.05.9l-1.12 7.106z"/>
                <path d="M20.952 6.285c-.145.803-.337 1.553-.587 2.258-1.72 4.86-5.943 6.557-10.7 6.557h-2.19a1.305 1.305 0 0 0-1.287 1.104l-.256 1.628-.706 4.519a.64.64 0 0 0 .632.74h4.407a.531.531 0 0 0 .523-.444l.021-.112.83-5.264.054-.285a.532.532 0 0 1 .523-.444h.328c2.13 0 4.07-.628 5.482-2.708 1.28-1.884 1.688-4.241 1.03-7.667-.087-.45-.21-.822-.38-1.142z"/>
            </svg>
            <span class="dashicons dashicons-arrow-right-alt viscribe-donate-card-arrow"></span>
        </a>
    </div>
    <div class="viscribe-header-right">
        <a href="{{ doc_url('usage/quick-start') }}" target="_blank" rel="noopener noreferrer" class="viscribe-header-icon-link" aria-label="{% trans %}Documentation{% endtrans %}" title="{% trans %}Documentation{% endtrans %}">
            <span class="dashicons dashicons-book"></span> </a> <a
            href="https://wordpress.org/plugins/viscribe/" target="_blank" rel="noopener noreferrer" class="viscribe-header-icon-link" aria-label="{% trans %}WordPress.org Plugin Page{% endtrans %}" title="{% trans %}Plugin Page{% endtrans %}">
            <span class="dashicons dashicons-wordpress"></span> </a> <a
            href="https://wordpress.org/support/plugin/viscribe/" target="_blank" rel="noopener noreferrer" class="viscribe-header-icon-link" aria-label="{% trans %}Support Forum{% endtrans %}" title="{% trans %}Support Forum{% endtrans %}">
            <span class="dashicons dashicons-format-chat"></span> </a> <a
            href="https://github.com/thaikolja/viscribe-wordpress-plugin" target="_blank" rel="noopener noreferrer" class="viscribe-header-icon-link" aria-label="{% trans %}GitHub Repository{% endtrans %}" title="{% trans %}GitHub Repository{% endtrans %}">
            <svg role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" />
            </svg>
        </a> <a
            href="https://gitlab.com/thaikolja/viscribe-wordpress-plugin" target="_blank" rel="noopener noreferrer" class="viscribe-header-icon-link" aria-label="{% trans %}GitLab Repository{% endtrans %}" title="{% trans %}GitLab Repository{% endtrans %}">
            <svg role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M22.65 14.39L12 22.13 1.35 14.39a.84.84 0 0 1-.3-.94l1.22-3.78 2.44-7.51A.42.42 0 0 1 4.82 2a.43.43 0 0 1 .58 0 .42.42 0 0 1 .11.18l2.44 7.49h8.1l2.44-7.51A.42.42 0 0 1 18.6 2a.43.43 0 0 1 .58 0 .42.42 0 0 1 .11.18l2.44 7.51L23 13.45a.84.84 0 0 1-.35.94z" />
            </svg>
        </a> <span class="viscribe-header-version code">
			v{{ version }}
		</span>
    </div>
</div>
