{# Introduction Section #}
<div class="viscribe-card viscribe-intro-card">
    <div class="viscribe-card-body">
        <div class="viscribe-intro-content">
            <div class="viscribe-intro-icon">
                <span class="dashicons dashicons-format-image"></span>
            </div>
            <div class="viscribe-intro-text">
                <h2 class="viscribe-intro-title">
                    {% trans %}Welcome to Viscribe{% endtrans %}
                </h2>
                <p class="viscribe-intro-description">
                    {% trans %}Automatically rename newly uploaded images with short, descriptive filenames based on their actual content. You can also reuse the generated description as alt text for better accessibility.{% endtrans %}
                    <strong>{% trans %}This version connects to Groq only.{% endtrans %}</strong>
                </p>
                <h3 class="viscribe-intro-subtitle">{% trans %}Quick Start Guide{% endtrans %}</h3>
                <div class="viscribe-intro-steps">
                    <div class="viscribe-step">
                        <div class="viscribe-step-indicator">1</div>
                        <div class="viscribe-step-content">
                            <span class="viscribe-step-title">{% trans %}Connect API{% endtrans %}</span>
                            <span class="viscribe-step-desc">{% trans %}Enter your Groq API key and test the connection first{% endtrans %}</span>
                        </div>
                    </div>
                    <div class="viscribe-step-separator"></div>
                    <div class="viscribe-step">
                        <div class="viscribe-step-indicator">2</div>
                        <div class="viscribe-step-content">
                            <span class="viscribe-step-title">{% trans %}Configure{% endtrans %}</span>
                            <span class="viscribe-step-desc">{% trans %}Choose your AI model, file types, and optional alt text behavior{% endtrans %}</span>
                        </div>
                    </div>
                    <div class="viscribe-step-separator"></div>
                    <div class="viscribe-step">
                        <div class="viscribe-step-indicator">3</div>
                        <div class="viscribe-step-content">
                            <span class="viscribe-step-title">{% trans %}Upload{% endtrans %}</span>
                            <span class="viscribe-step-desc">{% trans %}Upload images in Media → Library or through the block editor{% endtrans %}</span>
                        </div>
                    </div>
                    <div class="viscribe-step-separator"></div>
                    <div class="viscribe-step">
                        <div class="viscribe-step-indicator">4</div>
                        <div class="viscribe-step-content">
                            <span class="viscribe-step-title">{% trans %}Fallback{% endtrans %}</span>
                            <span class="viscribe-step-desc">
                                {% trans %}If the API request fails, WordPress keeps the original filename so uploads can still complete.{% endtrans %}
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
