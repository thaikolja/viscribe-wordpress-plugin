{# Donation Banner Component #}
<div class="viscribe-donation-banner" id="viscribe-donation-banner">
    <a href="https://www.paypal.me/thaikolja/10" target="_blank" class="viscribe-donation-banner-link" rel="noopener noreferrer">
        <div class="viscribe-donation-banner-content">
            <div class="viscribe-donation-banner-icon">
                <span class="dashicons dashicons-heart"></span>
            </div>
            <div class="viscribe-donation-banner-text">
                <h3>
                    {% trans %}Is this plugin useful to you? Let's make it even better!{% endtrans %}
                </h3>
                <p>
                    {% trans %}Maintining and keeping a plugin up-to-date requires a lot of work. Your donation helps me
                    as a single plugin developer to keep adding new features and improvements to the plugin. Every
                    contribution, big or small, is greatly appreciated and goes a long way!{% endtrans %}</p>
            </div>
            <div class="viscribe-donation-banner-cta">
                <button type="button" class="viscribe-donation-button">
                    <span class="dashicons dashicons-heart"></span>
                    {% trans %}Donate via PayPal{% endtrans %}
                </button>
            </div>
        </div>
    </a>
    <button type="button" class="viscribe-donation-banner-close" id="viscribe-donation-banner-close" aria-label="{% trans %}Close{% endtrans %}">
        <span class="dashicons dashicons-no-alt"></span>
    </button>
</div>
