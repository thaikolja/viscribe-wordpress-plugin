{# Tab Navigation Component #}
<nav class="viscribe-tabs" role="tablist">
	{% for tab_id, tab in tabs %}
		<button
			type="button"
			class="viscribe-tab{{ tab.active ? ' active' : '' }}"
			id="viscribe-tab-{{ tab_id }}"
			data-tab="{{ tab_id }}"
			role="tab"
			aria-selected="{{ tab.active ? 'true' : 'false' }}"
			aria-controls="viscribe-panel-{{ tab_id }}">
			<span class="dashicons {{ tab.icon }}"></span>
			<span class="viscribe-tab-label">{{ tab.label }}</span>
		</button>
	{% endfor %}
	<a
		href="{{ doc_url('usage/quick-start') }}"
		target="_blank"
		rel="noopener noreferrer"
		class="viscribe-tab">
		<span class="dashicons dashicons-welcome-learn-more"></span>
		<span class="viscribe-tab-label">{% trans %}Documentation{% endtrans %}</span>
	</a>
</nav>
