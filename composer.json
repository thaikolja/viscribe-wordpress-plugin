{
  "name":        "thaikolja/ai-image-renamer",
  "description": "A WordPress plugin that automatically renames uploaded images using Groq's Vision API for SEO-friendly filenames.",
  "type":        "wordpress-plugin",
  "license":     "GPL-2.0-or-later",
  "authors":     [
    {
      "name":     "Kolja Nolte",
      "email":    "kolja.nolte@gmail.com",
      "homepage": "https://www.kolja-nolte.com",
      "role":     "Developer"
    }
  ],
  "keywords":    [
    "wordpress",
    "plugin",
    "groq",
    "vision-api",
    "image-renaming"
  ],
  "homepage":    "https://gitlab.com/thaikolja/ai-image-renamer",
  "support":     {
    "docs":   "https://docs.kolja-nolte.com/ai-image-renamer",
    "forum":  "https://wordpress.org/support/plugin/ai-image-renamer/",
    "source": "https://gitlab.com/thaikolja/ai-image-renamer"
  },
  "require":     {
    "php":                   ">=8.2",
    "twig/twig":             "~v3.22.2",
    "defuse/php-encryption": "^v2.4"
  },
  "require-dev": {
    "kint-php/kint":             "^6.1.0",
    "phpstan/phpstan":           "^1.11",
    "squizlabs/php_codesniffer": "^3.10",
    "wp-coding-standards/wpcs":  "^3.0"
  },
  "autoload":    {
    "psr-4": {
      "AIR\\": "includes/"
    }
  },
  "scripts":     {
    "lint":    "php -l ai-image-renamer.php && find includes -name '*.php' -print0 | xargs -0 -n1 php -l",
    "phpstan": "phpstan analyse includes --no-progress",
    "phpcs":   "phpcs . --standard=vendor/wp-coding-standards/wpcs/WordPress",
    "phpcbf":  "phpcbf . --standard=vendor/wp-coding-standards/wpcs/WordPress"
  },
  "suggest":     {
    "wp-cli/wp-cli": "Useful for local development and automation."
  },
  "config":      {
    "optimize-autoloader": true,
    "sort-packages":       true,
    "allow-plugins":       {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
