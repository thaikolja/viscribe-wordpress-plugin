# Exclude development files
src/
node_modules/
scripts/
docs/

# Exclude source asset files (only built files should ship)
assets/js/main.js
assets/js/admin.js
assets/js/admin-tabs.js
assets/css/main.css

# Exclude source maps
assets/**/*.map

# Exclude configuration files
package.json
bun.lock
phpcs.xml.dist
vite.config.mjs
.gitignore
.distignore
.babelrc
.eslintignore
.eslintrc.json

# Exclude all markdown files (WordPress uses readme.txt)
*.md

# Exclude cache and system files
cache/
.DS_Store
*.zip
